# ============================================================
# Patrioti Mushrooms — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# MySQL database connection
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL=mysql://root:your_password@localhost:3306/patrioti_mushrooms

# Secret key for JWT session tokens — use a long random string
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_64_CHARACTERS

# App settings
VITE_APP_ID=patrioti-mushrooms
NODE_ENV=production

# Server port (default 3000)
PORT=3000

# Leave these empty — not used in current setup
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
